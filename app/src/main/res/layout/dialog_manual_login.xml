<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Token"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="2dp" />
    <EditText
        android:id="@+id/etToken"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="tR8MrTuIcv6SwII0z…"
        android:textSize="12sp"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="User ID"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="2dp" />
    <EditText
        android:id="@+id/etUserId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e4075f1de7a949d0…"
        android:textSize="12sp"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Device ID (phone)"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="2dp" />
    <EditText
        android:id="@+id/etDeviceId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="87ac20dd83afb24d"
        android:textSize="12sp"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Auth Code (robot)"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="2dp" />
    <EditText
        android:id="@+id/etAuthCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="1652660"
        android:textSize="12sp"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Robot ID (optional)"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="2dp" />
    <EditText
        android:id="@+id/etRobotId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="2ca3100ff0a548a9…"
        android:textSize="12sp"
        android:inputType="text" />

</LinearLayout>
